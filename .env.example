# =============================================
# ISMS - Intelligent Supply Management System
# Variables de Entorno (EJEMPLO)
# Copia este archivo a .env y completa tus valores
# =============================================

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Seguridad
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Base de Datos (configurar cuando esté listo)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=isms_db
# DB_USER=
# DB_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:3000
