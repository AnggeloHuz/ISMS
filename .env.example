# =============================================
# ISMS - Intelligent Supply Management System
# Variables de Entorno (EJEMPLO)
# Copia este archivo a .env y completa tus valores
# =============================================

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Seguridad
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sistema_gestion_abasto
DB_USER=
DB_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:3000
